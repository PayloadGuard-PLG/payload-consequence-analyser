+class TestComplexityAdvisory(unittest.TestCase):
+    def _run_structural(self, original, modified, path="mod.py", threshold=15):
+        return StructuralPayloadAnalyzer(
+            original, modified,
+            file_path=path,
+            complexity_threshold=threshold,
+        ).analyze_structural_drift()
