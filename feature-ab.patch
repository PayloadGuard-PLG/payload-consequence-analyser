+    def test_simple_function_below_threshold(self):
+        code = "def simple(x):\n    return x + 1\n"
+        result = self._run_structural("", code, threshold=15)
+        self.assertEqual(result['complexity_advisory'], [])
+
+    def test_complex_function_above_threshold(self):
+        # Manually construct a function with V(G) = 16
+        branches = "\n".join(f"    if x == {i}: pass" for i in range(15))
+        code = f"def complex_fn(x):\n{branches}\n    return x\n"
+        result = self._run_structural("", code, threshold=15)
+        names = [ca['name'] for ca in result['complexity_advisory']]
+        self.assertIn('complex_fn', names)
+
+    def test_complexity_value_correct(self):
+        # 5 if-statements → V(G) = 6
+        branches = "\n".join(f"    if x == {i}: pass" for i in range(5))
+        code = f"def fn(x):\n{branches}\n    return x\n"
+        result = self._run_structural("", code, threshold=5)
+        match = next((ca for ca in result['complexity_advisory'] if ca['name'] == 'fn'), None)
+        self.assertIsNotNone(match)
+        self.assertEqual(match['complexity'], 6)
+
+    def test_only_added_functions_checked(self):
+        original = "def existing(x):\n" + "\n".join(f"    if x == {i}: pass" for i in range(20)) + "\n    return x\n"
+        modified = original + "\ndef new_simple(x):\n    return x\n"
+        result = self._run_structural(original, modified, threshold=5)
+        names = [ca['name'] for ca in result['complexity_advisory']]
+        # existing() has high complexity but was not added — must not appear
